# Run evaluation on all datasets
# -----------------------------
mpjpe_per_dataset <- data.frame()
mpjpe_per_frame <- data.frame()
joint_mae_results <- data.frame()
for (i in seq_along(ground_truth_data_list)) {
result <- evaluate_dataset(
ground_truth_data_list[[i]],
prediction_data_list[[i]]
)
dataset_name <- paste("Dataset", i)
# Dataset MPJPE
mpjpe_per_dataset <- rbind(
mpjpe_per_dataset,
data.frame(
Dataset = dataset_name,
MPJPE = result$mpjpe_dataset
)
)
# Frame MPJPE
mpjpe_per_frame <- rbind(
mpjpe_per_frame,
data.frame(
Dataset = dataset_name,
Frame = result$frames,
MPJPE = result$mpjpe_per_frame
)
)
# Joint MAE
joint_mae_results <- rbind(
joint_mae_results,
data.frame(
Dataset = dataset_name,
Joint = paste0("Joint_", seq_along(result$joint_mae)-1),
MAE = result$joint_mae
)
)
}
# -----------------------------
# Results
# -----------------------------
print("MPJPE per dataset:")
print(mpjpe_per_dataset)
print("MPJPE per frame:")
head(mpjpe_per_frame)
print("Joint MAE:")
print(joint_mae_results)
View(joint_mae_results)
View(joint_mae_results)
plot(
ground_truth_data_list[[1]]$V2,
type="l"
)
gt <- ground_truth_data_list[[1]]
pred <- prediction_data_list[[1]]
merged <- inner_join(gt, pred, by = "Frame", suffix = c("_gt", "_pred"))
joint_col <- 2
plot(
merged$Frame,
merged[[joint_col]],
type = "l",
xlab = "Frame",
ylab = "Joint coordinate",
main = "Joint trajectory comparison"
)
lines(
merged$Frame,
merged[[joint_col + ncol(gt) - 1]],
col = "red"
)
legend(
"topright",
legend = c("Ground Truth", "Prediction"),
col = c("black", "red"),
lty = 1
)
joint_start <- 2
error <- sqrt(
(merged[[joint_start]] - merged[[joint_start + ncol(gt) - 1]])^2 +
(merged[[joint_start + 1]] - merged[[joint_start + ncol(gt)]])^2 +
(merged[[joint_start + 2]] - merged[[joint_start + ncol(gt) + 1]])^2
)
plot(
merged$Frame,
error,
type = "l",
xlab = "Frame",
ylab = "Joint error",
main = "Joint error over time"
)
plot(
mpjpe_per_frame$Frame,
mpjpe_per_frame$MPJPE,
type = "l",
xlab = "Frame",
ylab = "MPJPE",
main = "MPJPE over time"
)
