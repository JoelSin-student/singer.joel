merged[[joint_col + ncol(gt) - 1]],
col = "red"
)
legend(
"topright",
legend = c("Ground Truth", "Prediction"),
col = c("black", "red"),
lty = 1
)
joint_start <- 2
error <- sqrt(
(merged[[joint_start]] - merged[[joint_start + ncol(gt) - 1]])^2 +
(merged[[joint_start + 1]] - merged[[joint_start + ncol(gt)]])^2 +
(merged[[joint_start + 2]] - merged[[joint_start + ncol(gt) + 1]])^2
)
plot(
mpjpe_per_frame$Frame,
mpjpe_per_frame$MPJPE,
type = "l",
xlab = "Frame",
ylab = "MPJPE",
main = "MPJPE over time"
)
joint_mae_results$MAE_cm <- joint_mae_results$MAE * 100
# To have the joint names in the numeric order and not the alphabetical order
joint_names <- paste0("Joint_", seq_along(unique(joint_mae_results$Joint))-1)
joint_mae_results$Joint <- factor(
joint_mae_results$Joint,
levels = joint_names
)
ggplot(joint_mae_results, aes(x = Joint, y = Dataset, fill = MAE_cm)) +
geom_tile() +
scale_fill_gradient(
low = "blue",
high = "red",
name = "MAE (cm)"
) +
labs(
title = "Per-Joint Mean Absolute Error",
x = "Joint",
y = "Dataset"
) +
