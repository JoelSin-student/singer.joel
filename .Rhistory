# -----------------------------
# Load datasets
# -----------------------------
ground_truth_pattern <- "^Awinda_.*\\.csv$"
prediction_pattern <- "^Predicted_skeleton_.*\\.csv$"
ground_truth_files <- sort(list.files(
path = "data/test_data/skeleton/",
pattern = ground_truth_pattern,
full.names = TRUE
))
prediction_files <- sort(list.files(
path = "results/output/",
pattern = prediction_pattern,
full.names = TRUE
))
ground_truth_data_list <- lapply(ground_truth_files, read.csv)
prediction_data_list <- lapply(prediction_files, read.csv)
# -----------------------------
# Function: evaluate one dataset
# -----------------------------
evaluate_dataset <- function(gt_df, pred_df) {
# Align frames
merged <- inner_join(gt_df, pred_df, by = "Frame", suffix = c("_gt", "_pred"))
if (nrow(merged) == 0) {
stop("No matching frames between prediction and ground-truth.")
}
# Extract coordinate matrices
gt_cols <- grep("_gt$", names(merged))
pred_cols <- grep("_pred$", names(merged))
gt <- as.matrix(merged[, gt_cols])
pred <- as.matrix(merged[, pred_cols])
diff <- gt - pred
n_frames <- nrow(diff)
n_joints <- ncol(diff) / 3
diff_array <- array(diff, dim = c(n_frames, 3, n_joints))
# Euclidean joint error
joint_errors <- sqrt(apply(diff_array^2, c(1,3), sum))
# MPJPE per frame
mpjpe_per_frame <- rowMeans(joint_errors)
# MPJPE per dataset
mpjpe_dataset <- mean(mpjpe_per_frame)
# Joint MAE
joint_mae <- colMeans(joint_errors)
list(
frames = merged$Frame,
mpjpe_per_frame = mpjpe_per_frame,
mpjpe_dataset = mpjpe_dataset,
joint_mae = joint_mae
)
}
# -----------------------------
# Run evaluation on all datasets
# -----------------------------
mpjpe_per_dataset <- data.frame()
mpjpe_per_frame <- data.frame()
joint_mae_results <- data.frame()
for (i in seq_along(ground_truth_data_list)) {
result <- evaluate_dataset(
ground_truth_data_list[[i]],
prediction_data_list[[i]]
)
dataset_name <- paste("Dataset", i)
# Dataset MPJPE
mpjpe_per_dataset <- rbind(
mpjpe_per_dataset,
data.frame(
Dataset = dataset_name,
MPJPE = result$mpjpe_dataset
)
)
# Frame MPJPE
mpjpe_per_frame <- rbind(
mpjpe_per_frame,
data.frame(
Dataset = dataset_name,
Frame = result$frames,
MPJPE = result$mpjpe_per_frame
)
)
# Joint MAE
joint_mae_results <- rbind(
joint_mae_results,
data.frame(
Dataset = dataset_name,
Joint = paste0("Joint_", seq_along(result$joint_mae)-1),
MAE = result$joint_mae
)
)
}
# -----------------------------
# Results
# -----------------------------
print("MPJPE per dataset:")
print(mpjpe_per_dataset)
print("MPJPE per frame:")
head(mpjpe_per_frame)
print("Joint MAE:")
print(joint_mae_results)
