# Predict epoch at which validation loss will be minimal, and corresponding training loss
pred_soleformer <- exp(predict(fit_soleformer, newdata = data.frame(epoch = 1:200)))
min_epoch_soleformer <- seq(1, 200, by = 1)[which.min(pred_soleformer)]
train_loss_soleformer <- predict(fit_soleformer, newdata = data.frame(epoch = min_epoch_soleformer))
# Print results
cat("SoleFormer: epoch =", min_epoch_soleformer, "train_loss =", train_loss_soleformer, "\n")
# Merge true data and predicted curves
epochs <- 1:200
pred_soleformer <- predict(fit_soleformer, newdata = data.frame(epoch = epochs))
plot_df <- data.frame(
epoch = epochs,
pred = pred_soleformer
)
plot_df$true <- NA
plot_df$true[1:nrow(training_soleformer)] <- training_soleformer$val_loss
# Plot true data and predicted curves for each model
ggplot(plot_df, aes(epoch)) +
geom_line(aes(y = true, color = "true")) +
geom_line(aes(y = pred, color = "pred")) +
theme_minimal()
fit_loess <- loess(val_loss ~ epoch, data = training_soleformer)
epochs <- 1:200
pred <- predict(fit_loess, newdata = data.frame(epoch = epochs))
opt_epoch <- epochs[which.min(pred)]
opt_loss  <- min(pred, na.rm = TRUE)
patience <- 5
best_loss <- Inf
best_epoch <- NA
counter <- 0
for (i in seq_along(training_soleformer$val_loss)) {
loss <- training_soleformer$val_loss[i]
if (loss < best_loss) {
best_loss <- loss
best_epoch <- training_soleformer$epoch[i]
counter <- 0
} else {
counter <- counter + 1
}
if (counter >= patience) break
}
cat("Early stopping epoch =", best_epoch, "\n")
epochs <- 1:200
pred <- predict(fit_loess, newdata = data.frame(epoch = epochs))
plot_df <- data.frame(
epoch = epochs,
smooth = pred,
true = NA
)
plot_df$true[1:nrow(training_soleformer)] <- training_soleformer$val_loss
ggplot(plot_df, aes(epoch)) +
geom_line(aes(y = true, color = "true")) +
geom_line(aes(y = smooth, color = "smooth")) +
geom_vline(xintercept = opt_epoch, linetype = "dashed") +
theme_minimal()
# Fit exponential regression to training and validation losses of SoleFormer
fit_soleformer <- lm(log(val_loss) ~ log(epoch), data = training_soleformer)
# Predict epoch at which validation loss will be minimal, and corresponding training loss
epochs <- 1:200
pred_soleformer <- exp(predict(fit_soleformer, newdata = data.frame(epoch = epochs)))
min_epoch_soleformer <- epochs[which.min(pred_soleformer)]
train_loss_soleformer <- exp(predict(fit_soleformer, newdata = data.frame(epoch = min_epoch_soleformer)))
# Print results
cat("SoleFormer: epoch =", min_epoch_soleformer, "train_loss =", train_loss_soleformer, "\n")
# Merge true data and predicted curves
plot_df <- data.frame(
epoch = epochs,
pred = pred_soleformer,
true = NA
)
plot_df$true[1:nrow(training_soleformer)] <- training_soleformer$val_loss
# Plot true data and predicted curves for each model
ggplot(plot_df, aes(epoch)) +
geom_line(aes(y = true, color = "true")) +
geom_line(aes(y = pred, color = "pred")) +
theme_minimal()
# Fit exponential regression to training and validation losses of SoleFormer
fit_soleformer <- lm(val_loss ~ epoch + I(epoch^2), data = training_soleformer)
# Predict epoch at which validation loss will be minimal, and corresponding training loss
epochs <- 1:200
pred_soleformer <- exp(predict(fit_soleformer, newdata = data.frame(epoch = epochs)))
min_epoch_soleformer <- epochs[which.min(pred_soleformer)]
train_loss_soleformer <- exp(predict(fit_soleformer, newdata = data.frame(epoch = min_epoch_soleformer)))
# Print results
cat("SoleFormer: epoch =", min_epoch_soleformer, "train_loss =", train_loss_soleformer, "\n")
# Merge true data and predicted curves
plot_df <- data.frame(
epoch = epochs,
pred = pred_soleformer,
true = NA
)
plot_df$true[1:nrow(training_soleformer)] <- training_soleformer$val_loss
# Plot true data and predicted curves for each model
ggplot(plot_df, aes(epoch)) +
geom_line(aes(y = true, color = "true")) +
geom_line(aes(y = pred, color = "pred")) +
theme_minimal()
